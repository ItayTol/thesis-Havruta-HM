\n","\n","# Step 2: Feed them to the distinct-rule selector\n","kept, redundant, corr = select_distinct_rules(rules_with_stats, threshold=0.87)\n","\n","data_folder = r\"/content/drive/MyDrive/thesis/DATA/\"\n","pd.DataFrame(kept).to_excel(os.path.join(data_folder, \"rules_v0.xlsx\"),\n","                            index=False,sheet_name = \"extraversion\")\n","pd.DataFrame(redundant).to_excel(os.path.join(data_folder, \"redundant_rules (from generating rules_v0).xlsx\"),\n","                                 index=False, sheet_name = \"extraversion\")"]},{"cell_type":"markdown","metadata":{"id":"Mktihu0ijyxj"},"source":["# load_rule_set"]},{"cell_type":"code","execution_count":45,"metadata":{"executionInfo":{"elapsed":28,"status":"ok","timestamp":1772208348506,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"},"user_tz":-120},"id":"WfzYSlR1cSZB"},"outputs":[],"source":["def load_rule_set(personality_trait: str, version, psych: str = None):\n","    if psych:\n","        df = pd.read_excel(fr\"/content/drive/MyDrive/thesis/DATA/rules_v{version}_{psych}.xlsx\",\n","                           sheet_name=load_trait(personality_trait))\n","    else:\n","        df = pd.read_excel(fr\"/content/drive/MyDrive/thesis/DATA/rules_v{version}.xlsx\",\n","                           sheet_name=load_trait(personality_trait))\n","\n","    # 'records' orientation (list of dictionaries, each representing a row)\n","    json_records = df.to_json(orient='records', indent = 4)\n","    list_of_rules = json.loads(json_records)\n","    return list_of_rules"]},{"cell_type":"markdown","metadata":{"id":"-gvoKz_ebuIP"},"source":["# Final Stage:\n","*   Zero Shot\n","*   Few Shot\n","*   Rule Based\n","*    XGBoost with SBert Embeddings"]},{"cell_type":"code","execution_count":51,"metadata":{"executionInfo":{"elapsed":136,"status":"ok","timestamp":1772210235070,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"},"user_tz":-120},"id":"OZgsVvPWN9Oe"},"outputs":[],"source":["def run_pipeline(\n","    version: str,\n","    true_label_type: str,\n","    reps: int,\n","    num_classes: int,\n","    psych: str = None\n","):\n","\n","    print('version -', version, '; psych -', psych, '; num_classes -', num_classes, '; true_label_type -', true_label_type)\n","    summary_results_test = []\n","    df_rep_summary = []\n","    metrics_test_list = []\n","    results_test_list = []\n","    for personality_trait in ['e']:\n","    # ['a', 'n', 'c', 'o', 'e']:\n","        final_test_dir_root: str = r\"/content/drive/MyDrive/thesis/final test\"\n","        # --- results folders ---\n","        trait_folder = f\"{load_trait(personality_trait)}\"\n","        now = datetime.datetime.now() + datetime.timedelta(hours=2)\n","        now_txt = now.strftime(\"%Y-%m-%d_%H-%M-%S\")\n","        base_path = os.path.join(\n","            final_test_dir_root,\n","            f\"run_{now_txt} - Version{version}_{psych}_{num_classes}_{true_label_type} - test 6 samples\",\n","            trait_folder\n","        )\n","        os.makedirs(base_path, exist_ok=True)\n","\n","        subdirs = {\n","            \"few_shot_examples\": os.path.join(base_path, \"_meta\"),\n","            \"pred_probas\": os.path.join(base_path, \"_meta\"),\n","        }\n","        for p in subdirs.values():\n","            os.makedirs(p, exist_ok=True)\n","        train = load_posts_and_trait_true_label(personality_trait, num_classes, true_label_type, \"train\")\n","        final_test = load_posts_and_trait_true_label(personality_trait, num_classes, true_label_type, \"final_test\")\n","        final_test = final_test.sample(n=8 , random_state=42)\n","        rules = load_rule_set(personality_trait, version, psych)\n","\n","        for rep in range(1, reps + 1):\n","            few_shot_examples = build_few_shot_block(personality_trait, num_classes, true_label_type)\n","\n","            # # Store few-shot block (helps tracing)\n","            with open(os.path.join(subdirs[\"few_shot_examples\"], f\"FEW_SHOT_EXAMPLES_OUTER{rep}.txt\"), \"w\", encoding=\"utf-8\") as f:\n","                if isinstance(few_shot_examples, (dict, list)):\n","                    f.write(json.dumps(few_shot_examples, ensure_ascii=False, indent=2))\n","                else:\n","                    f.write(str(few_shot_examples))\n","            # true label type can be either 'percentiles' or 'fixed ranges'\n","            personality_trait_true_label = f'{personality_trait} by {true_label_type}'\n","            yte = final_test[personality_trait_true_label]\n","\n","            time_stamp('RULE-BASED STARTED')\n","            # (a) Rule-based\n","            pred_rules, reses_rules, justification_rules, score_explanation_rules, reasoning_process_rules = [], [], [], [], []\n","            y_pred_proba_rules = []\n","            i=0\n","            for _, row in final_test.iterrows():\n","                i=i+1\n","                print(i, '/', len(final_test))\n","                while True:\n","                    res = rank_rules_and_classify(personality_trait, row[\"post1\"], row[\"post2\"], rules, num_classes)\n","                    loaded = json.loads(res)\n","                    if loaded:\n","                        res = json.loads(res)\n","                        indented_res = json.dumps(res, ensure_ascii=False, indent=2)\n","                        break\n","                reses_rules.append(indented_res)\n","                pred_rules.append(res[\"trait_classification\"][\"classified_level\"])\n","                y_pred_proba_rules.append(res[\"trait_classification\"][\"classification_probabilities\"])\n","                justification_rules.append(res[\"trait_classification\"][\"justification\"])\n","                reasoning_process_rules.append(res[\"trait_classification\"][\"reasoning_process\"])\n","                score_explanation_rules.append(res[\"trait_classification\"][\"score_explanation\"])\n","\n","            ok_rules = [int(pred == true) for pred, true in zip(pred_rules, yte)]\n","\n","            with open(os.path.join(subdirs[\"pred_probas\"], f\"pred_probas_OUTER{rep}.txt\"), \"w\", encoding=\"utf-8\") as f:\n","                if isinstance(y_pred_proba_rules, (dict, list)):\n","                    f.write(json.dumps(y_pred_proba_rules, ensure_ascii=False, indent=2))\n","                else:\n","                    f.write(str(y_pred_proba_rules))\n","\n","            df_res_rules = pd.DataFrame({'rep': rep, \"p\": final_test.get(\"p\"),\n","                                        \"post1\": final_test[\"post1\"], \"post2\": final_test[\"post2\"],\n","                                        'true': final_test[personality_trait_true_label],\n","                                        \"pred_rules\": pred_rules, 'justification_rules':justification_rules,\n","                                        \"y_pred_proba_rules\": y_pred_proba_rules, 'res_rules': reses_rules, 'accuracy_rules': ok_rules})\n","            summary_results_test.append(get_summary_results_test(yte, pred_rules, rep, \"rules_based\", version, psych, num_classes, true_label_type))\n","\n","            #----------------------------------------------------\n","            time_stamp('ZERO SHOT STARTED')\n","            # (b) Zero-shot\n","            pred_zero, reses_zero, justification_zero, score_explanation_zero, reasoning_process_zero = [], [], [], [], []\n","            y_pred_proba_zero = []\n","            i=0\n","            for _, row in final_test.iterrows():\n","                i=i+1\n","                print(i, '/', len(final_test))\n","                while True:\n","                    res = evaluate_zero_shot(personality_trait, row[\"post1\"], row[\"post2\"], num_classes)\n","                    if json.loads(res):\n","                        res = json.loads(res)\n","                        break\n","                indented_res = json.dumps(res, ensure_ascii=False, indent=2)\n","                reses_zero.append(indented_res)\n","                pred_zero.append(res[\"classified_level\"])\n","                y_pred_proba_zero.append(res[\"classification_probabilities\"])\n","                justification_zero.append(res[\"justification\"])\n","                reasoning_process_zero.append(res[\"reasoning_process\"])\n","                score_explanation_zero.append(res[\"score_explanation\"])\n","\n","            with open(os.path.join(subdirs[\"pred_probas\"], f\"pred_probas_zero_OUTER{rep}.txt\"), \"w\", encoding=\"utf-8\") as f:\n","                if isinstance(y_pred_proba_zero, (dict, list)):\n","                    f.write(json.dumps(y_pred_proba_zero, ensure_ascii=False, indent=2))\n","                else:\n","                    f.write(str(y_pred_proba_zero))\n","\n","            ok_zero = [int(pred == true) for pred, true in zip(pred_zero, yte)]\n","            df_res_zero = pd.DataFrame({\"rep\": rep, \"p\": final_test.get(\"p\"), \"pred_zero\": pred_zero,\n","                                        \"y_pred_proba_zero\": y_pred_proba_zero, \"reasoning_process_zero\": reasoning_process_zero,\n","                                        \"score_explanation_zero\": score_explanation_zero,\n","                                        'justification_zero': justification_zero, \"accuracy_zero\": ok_zero})\n","            summary_results_test.append(get_summary_results_test(yte, pred_zero, rep, \"zero_shot\", version, psych, num_classes, true_label_type))\n","\n","            # --------------------------------------------------\n","            time_stamp('FEW SHOT STARTED')\n","            # (c) Few-shot (using DEV-derived examples)\n","            pred_few, reses_few, justification_few, reasoning_process_few, score_explanation_few = [], [], [], [], []\n","            y_pred_proba_few = []\n","            i=0\n","            for _, row in final_test.iterrows():\n","                i=i+1\n","                print(i, '/', len(final_test))\n","                while True:\n","                    res = evaluate_few_shot(personality_trait, row[\"post1\"], row[\"post2\"], few_shot_examples, num_classes)\n","                    if json.loads(res):\n","                        res = json.loads(res)\n","                        break\n","                indented_res = json.dumps(res, ensure_ascii=False, indent=2)\n","                reses_few.append(indented_res)\n","                pred_few.append(res[\"classified_level\"])\n","                y_pred_proba_few.append(res[\"classification_probabilities\"])\n","\n","                justification_few.append(res[\"justification\"])\n","                reasoning_process_few.append(res[\"reasoning_process\"])\n","                score_explanation_few.append(res[\"score_explanation\"])\n","\n","            with open(os.path.join(subdirs[\"pred_probas\"], f\"pred_probas_few_OUTER{rep}.txt\"), \"w\", encoding=\"utf-8\") as f:\n","                if isinstance(y_pred_proba_few, (dict, list)):\n","                    f.write(json.dumps(y_pred_proba_few, ensure_ascii=False, indent=2))\n","                else:\n","                    f.write(str(y_pred_proba_few))\n","\n","            ok_few = [int(pred == true) for pred, true in zip(pred_few, yte)]\n","            df_res_few = pd.DataFrame({\"rep\": rep , \"p\": final_test.get(\"p\"), \"pred_few\": pred_few,\n","                                       'accuracy_few': ok_few, \"justification_few\": justification_few,\n","                                       \"y_pred_proba_few\": y_pred_proba_few,\n","                                       \"reasoning_process_few\": reasoning_process_few, \"score_explanation_few\": score_explanation_few})\n","            summary_results_test.append(get_summary_results_test(yte, pred_few, rep, \"few_shot\", version, psych, num_classes, true_label_type))\n","\n","            # -----------------------------\n","            time_stamp('XGBOOST STARTED')\n","            # (d) Using S-bert embeddings and classify with xgboost\n","\n","            le = LabelEncoder()\n","            # sbert_model = \"cardiffnlp/twitter-roberta-base-2022-154m\"\n","            sbert_model = \"all-MiniLM-L6-v2\"\n","            sbert = SentenceTransformer(sbert_model)\n","            # sbert = AutoTokenizer.from_pretrained(sbert_model)\n","            train_embedded_post1 = sbert.encode(train['post1'].tolist(), batch_size=64, convert_to_numpy=True)\n","            train_embedded_post2 = sbert.encode(train['post2'].tolist(), batch_size=64, convert_to_numpy=True)\n","            train_embedded_text = np.mean([train_embedded_post1, train_embedded_post2], axis = 0)\n","\n","            test_embedded_post1 = sbert.encode(final_test['post1'].tolist(), batch_size=64, convert_to_numpy=True)\n","            test_embedded_post2 = sbert.encode(final_test['post2'].tolist(), batch_size=64, convert_to_numpy=True)\n","            test_embedded_text = np.mean([test_embedded_post1, test_embedded_post2], axis = 0)\n","\n","            xtr, ytr = train_embedded_text, le.fit_transform(train[personality_trait_true_label])\n","            xte, yte = test_embedded_text , le.transform(final_test[personality_trait_true_label])\n","\n","            clf = XGBClassifier(\n","            n_estimators=600,\n","            learning_rate=0.05,\n","            max_depth=8,\n","            subsample=0.9,\n","            colsample_bytree=0.9,\n","            reg_lambda=1.0,\n","            random_state=42,\n","            tree_method=\"auto\",\n","            n_jobs=-1\n","        )\n","\n","            clf.fit(xtr, ytr)\n","\n","            y_pred_proba_xgboost = clf.predict_proba(xte)\n","            y_pred_proba_xgboost = np.array(y_pred_proba_xgboost)\n","\n","            pred_xgboost = y_pred_proba_xgboost.argmax(axis=1)\n","            pred_xgboost_decoded = le.inverse_transform(pred_xgboost)\n","            ok_xgboost = [int(pred == true) for pred, true in zip(pred_xgboost, yte)]\n","            df_res_xgboost = pd.DataFrame({'rep': rep, \"p\": final_test.get(\"p\"),\n","                                        \"pred_xgboost\": pred_xgboost_decoded, \"accuracy_xgboost\": ok_xgboost})\n","            summary_results_test.append(get_summary_results_test(yte, pred_xgboost, rep, \"xgboost\", version, psych, num_classes, true_label_type))\n","\n","            # Merging the results of all models into one Data Frame\n","            rule_zero_merged = pd.merge(df_res_rules, df_res_zero, on = [\"p\", \"rep\"], how = \"inner\")\n","            rule_zero_few_merged = pd.merge(rule_zero_merged, df_res_few, on = [\"p\", \"rep\"], how = \"inner\")\n","            results_rep_test = pd.merge(rule_zero_few_merged, df_res_xgboost, on = [\"p\", \"rep\"], how = \"inner\")\n","            results_test_list.append(results_rep_test)\n","\n","            df_rep_summary = pd.DataFrame(summary_results_test)\n","\n","            metrics_test_list.append(df_rep_summary)\n","\n","            # Save outer rep summary\n","            if reps > 1:\n","                results_rep_test.to_csv(os.path.join(base_path, f\"TEST-FULL-Rep{rep} out of {reps}-RESULTS Version{version}_{psych}_{num_classes}_{true_label_type}.csv\"), index=False, encoding=\"utf-8-sig\")\n","\n","                df_rep_summary.to_csv(os.path.join(base_path, f\"TEST-Rep{rep} out of {reps}-SUMMARY Version{version}_{psych}_{num_classes}_{true_label_type}.csv\"),  index=False, encoding=\"utf-8-sig\")\n","\n","                methods = [\"Rule-Based\", \"Few Shot\", \"Zero Shot\", \"XGBoost with sbert embeddings\"]\n","                y_preds = [results_rep_test['pred_rules'], results_rep_test['pred_few'],\n","                                results_rep_test['pred_zero'], results_rep_test['pred_xgboost']]\n","                y_pred_probas = [y_pred_proba_rules, y_pred_proba_few, y_pred_proba_zero, y_pred_proba_xgboost]\n","\n","                if num_classes == 2:\n","                    labels = [\"Low\", \"Unknown\", \"High\"]\n","                elif num_classes == 3:\n","                    labels = [\"Low\", \"Unknown\", \"Moderate\", \"High\"]\n","\n","                for method, y_pred_method ,y_pred_proba_method in zip(methods, y_preds, y_pred_probas):\n","                    plot_confusion_matrix(true, y_pred_method, labels,\n","                        f\"{method} Confusion Matrix rep {rep}/{reps}\",\n","                                            os.path.join(base_path, f\"{method} Confusion Matrix rep ({rep} out of {reps}).png\"))\n","                    if num_classes == 2:\n","                        plot_roc_auc_curve_binary(true, y_pred_proba_method, labels,\n","                            f\"{method} ROC AUC Curve rep {rep}/{reps}\",\n","                                            os.path.join(base_path, f\"{method} ROC AUC Curve rep ({rep} out of {reps}).png\"))\n","\n","                    elif num_classes == 3:\n","                        plot_roc_auc_curve_multiclass(true, y_pred_proba_method, labels,\n","                            f\"{method} ROC AUC Curve rep {rep}/{reps}\",\n","                                            os.path.join(base_path, f\"{method} ROC AUC Curve rep ({rep} out of {reps}).png\"))\n","\n","            try:\n","                true = results_rep_test['true']\n","            except:\n","                true = results_rep_test['TRUE']\n","\n","    # --- Final summary ---\n","    try:\n","        results_test = pd.concat(results_test_list)\n","        df_summary = pd.concat(metrics_test_list)\n","    except:\n","        results_test = results_rep_test\n","\n","    results_test.to_csv(os.path.join(base_path, f\"TEST-FULL-RESULTS Version{version}_{psych}_{num_classes}_{true_label_type}.csv\"), index=False, encoding=\"utf-8-sig\")\n","    df_summary.to_csv(os.path.join(base_path, f\"TEST-Rep{rep} out of {reps}-SUMMARY Version{version}_{psych}_{num_classes}_{true_label_type}.csv\"),  index=False, encoding=\"utf-8-sig\")\n","\n","    try:\n","        true = results_test['true']\n"