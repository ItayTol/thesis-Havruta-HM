s.append(\n","            f\"Example {i+1}\\n\"\n","            f\"Texts:\\n1. {row['post1']}\\n2. {row['post2']}\\n\"\n","            f\"{load_trait(personality_trait)} level: {row[f'{personality_trait} by {true_label_type}']}\\n\"\n","        )\n","    return \"\\n\".join(lines)"]},{"cell_type":"markdown","source":["### extract_values_to_list"],"metadata":{"id":"6ifduu4T9s50"}},{"cell_type":"code","source":["def extract_values_to_list(data_dict):\n","    return list(data_dict.values())"],"metadata":{"id":"86k_JzIk9ii0","executionInfo":{"status":"ok","timestamp":1772361324120,"user_tz":-120,"elapsed":21,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"}}},"execution_count":1,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"7GpvOWi1P7dO"},"source":["### plot_roc_auc_curve binary classification\n"]},{"cell_type":"code","execution_count":17,"metadata":{"executionInfo":{"elapsed":38,"status":"ok","timestamp":1772206209627,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"},"user_tz":-120},"id":"O-RRFW-jPwdc"},"outputs":[],"source":["def plot_roc_auc_curve_binary(y_true, y_pred_proba, labels, title=\"roc_auc_curve\", save_path=None):\n","    \"\"\"\n","    Calculate ROC curve\n","    Plot the ROC curve\n","\n","    Parameters:\n","    - y_true: list of true class labels\n","    - y_pred_proba: list of probalility of predicted class labels\n","    - labels: list of class labels (e.g., [\"Low\", \"High\"])\n","    - title: plot title\n","    - save_path: file path to save the image (e.g., \"cmatrix.png\"). If None, does not save.\n","    \"\"\"\n","\n","    fpr, tpr, thresholds = roc_curve(y_true, y_pred_proba)\n","    roc_auc = auc(fpr, tpr)\n","    plt.figure()\n","    plt.plot(fpr, tpr, label='ROC curve (area = %0.2f)' % roc_auc)\n","    plt.plot([0, 1], [0, 1], 'k--', label='No Skill')\n","    plt.xlim([0.0, 1.0])\n","    plt.ylim([0.0, 1.05])\n","    plt.xlabel('False Positive Rate')\n","    plt.ylabel('True Positive Rate')\n","    plt.title(title, color='white')\n","    plt.legend()\n","    plt.tight_layout()\n","    if save_path:\n","        plt.savefig(save_path, facecolor='black', dpi=300)"]},{"cell_type":"markdown","metadata":{"id":"JDs65AaDrUp3"},"source":["### plot_roc_auc_curve multiclass classification\n"]},{"cell_type":"code","execution_count":18,"metadata":{"executionInfo":{"elapsed":9,"status":"ok","timestamp":1772206209640,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"},"user_tz":-120},"id":"RtpoyZE6rUqA"},"outputs":[],"source":["from sklearn.preprocessing import label_binarize\n","from sklearn.metrics import roc_curve, auc\n","import matplotlib.pyplot as plt\n","import numpy as np\n","\n","def plot_roc_auc_curve_multiclass(y_true, y_pred_proba, labels, title=\"roc_auc_curve\", save_path=None):\n","    \"\"\"\n","    Calculate ROC curve\n","    Plot the ROC curve for multiclass classification using One-vs-Rest strategy.\n","\n","    Parameters:\n","    - y_true: list of true class labels (e.g., [\"Low\", \"Moderate\", \"High\"])\n","    - y_pred_proba: numpy array of predicted probabilities, shape (n_samples, n_classes)\n","    - labels: list of class labels (e.g., [\"Low\", \"Moderate\", \"High\"]) - must match order of y_pred_proba columns\n","    - title: plot title\n","    - save_path: file path to save the image (e.g., \"cmatrix.png\"). If None, does not save.\n","    \"\"\"\n","\n","    # Binarize the true labels\n","    y_true_binarized = label_binarize(y_true, classes=labels)\n","    n_classes = len(labels)\n","\n","    # Compute ROC curve and ROC area for each class\n","    fpr = dict()\n","    tpr = dict()\n","    roc_auc = dict()\n","\n","    plt.figure(figsize=(10, 8))\n","    for i in range(n_classes):\n","        fpr[i], tpr[i], _ = roc_curve(y_true_binarized[:, i], y_pred_proba[:, i])\n","        roc_auc[i] = auc(fpr[i], tpr[i])\n","        plt.plot(fpr[i], tpr[i], label=f'ROC curve of class {labels[i]} (area = {roc_auc[i]:0.2f})')\n","\n","    # Compute micro-average ROC curve and ROC area\n","    fpr[\"micro\"], tpr[\"micro\"], _ = roc_curve(y_true_binarized.ravel(), y_pred_proba.ravel())\n","    roc_auc[\"micro\"] = auc(fpr[\"micro\"], tpr[\"micro\"])\n","\n","    plt.plot(fpr[\"micro\"], tpr[\"micro\"],\n","             label=f'micro-average ROC curve (area = {roc_auc[\"micro\"]:0.2f})',\n","             color='deeppink', linestyle=':', linewidth=4)\n","\n","    plt.plot([0, 1], [0, 1], 'k--', label='No Skill')\n","    plt.xlim([0.0, 1.0])\n","    plt.ylim([0.0, 1.05])\n","    plt.xlabel('False Positive Rate', color='white')\n","    plt.ylabel('True Positive Rate', color='white')\n","    plt.title(title, color='white')\n","    plt.legend(loc=\"lower right\")\n","    plt.xticks(color='white') # Ensure ticks are white\n","    plt.yticks(color='white') # Ensure ticks are white\n","    plt.tight_layout()\n","\n","    if save_path:\n","        plt.savefig(save_path, facecolor='black', dpi=300)\n","    plt.show()"]},{"cell_type":"markdown","source":["### calculating classification metrics and summarizing"],"metadata":{"id":"WhjDvcQtYcJh"}},{"cell_type":"code","source":["def calc_metrics(yte, pred):\n","    metrics = {\n","        \"accuracy\": accuracy_score(yte, pred),\n","        \"macro_precision\": precision_score(yte, pred, average=\"macro\", zero_division=0),\n","        \"macro_recall\": recall_score(yte, pred, average=\"macro\", zero_division=0),\n","        \"macro_f1\": f1_score(yte, pred, average=\"macro\", zero_division=0),\n","        \"weighted_precision\": precision_score(yte, pred, average=\"weighted\", zero_division=0),\n","        \"weighted_recall\": recall_score(yte, pred, average=\"weighted\", zero_division=0),\n","        \"weighted_f1\": f1_score(yte, pred, average=\"weighted\", zero_division=0)\n","        }\n","    return metrics\n","\n","def get_summary_results_test(yte, pred, rep, method, version, psych, num_classes, true_label_type):\n","    metrics = calc_metrics(yte, pred