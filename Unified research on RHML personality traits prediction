laYNh"},"source":["## Combine per-rule usage statistics from CSV with the full rule definitions."]},{"cell_type":"code","execution_count":29,"metadata":{"id":"dGzE7cQrRrtZ","executionInfo":{"status":"ok","timestamp":1772206253663,"user_tz":-120,"elapsed":24,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"}}},"outputs":[],"source":["def get_rules_with_stats(path: str, rules_json_path: str):\n","    \"\"\"\n","    Combine per-rule usage statistics from CSV with the full rule definitions.\n","\n","    Args:\n","        path (str): path to CSV file with 'res_rules' and 'accuracy_rules' columns.\n","        rules_json_path (str): path to JSON file containing the original rules list.\n","\n","    Returns:\n","        list[dict]: rules enriched with fields:\n","            - rule_applied_counts (int)\n","            - rule_correct_matches (int)\n","            - alignment_rate (float, 0–1)\n","    \"\"\"\n","    # ---- Step 1: load rules file (the base definitions) ----\n","    with open(rules_json_path, \"r\", encoding=\"utf-8\") as f:\n","        all_rules = json.load(f)\n","\n","    # Create lookup by rule_name\n","    rule_lookup = {r[\"rule_name\"]: r for r in all_rules}\n","\n","    # ---- Step 2: compute stats from classification CSV ----\n","    rule_stats = defaultdict(lambda: {\"rule_applied_counts\": 0, \"rule_correct_matches\": 0})\n","    df = pd.read_csv(path)\n","    res_rules_str = list(df[\"res_rules\"])\n","    accuracy_rules = list(df[\"accuracy_rules\"])\n","    res_rules_json = [json.loads(res) for res in res_rules_str]\n","\n","    for response, accuracy_val in zip(res_rules_json, accuracy_rules):\n","        rule_matches = response.get(\"rule_matches\", [])\n","        for rm in rule_matches:\n","            if rm.get(\"rule_applies\"):\n","                name = rm[\"rule_name\"]\n","                rule_stats[name][\"rule_applied_counts\"] += 1\n","                if accuracy_val == 1:\n","                    rule_stats[name][\"rule_correct_matches\"] += 1\n","\n","    # Compute alignment_rate for each rule\n","    for name, st in rule_stats.items():\n","        applied = st[\"rule_applied_counts\"]\n","        correct = st[\"rule_correct_matches\"]\n","        st[\"alignment_rate\"] = round(correct / applied, 2) if applied > 0 else 0.0\n","\n","    # ---- Step 3: merge stats into full rule dicts ----\n","    enriched_rules = []\n","    for name, stats in rule_stats.items():\n","        if name in rule_lookup:\n","            base = rule_lookup[name].copy()\n","            base.update(stats)\n","            enriched_rules.append(base)\n","        else:\n","            # fallback in case the rule wasn't in your JSON set\n","            enriched_rules.append({\n","                \"rule_name\": name,\n","                \"behavior_rule\": \"\",\n","                \"rule_applied_counts\": stats[\"rule_applied_counts\"],\n","                \"alignment_rate\": stats[\"alignment_rate\"]\n","            })\n","\n","    # Optional: sort by number of applications (descending)\n","    enriched_rules.sort(key=lambda r: r[\"rule_applied_counts\"], reverse=True)\n","\n","    return enriched_rules"]},{"cell_type":"markdown","metadata":{"id":"rh_LigPvtY8e"},"source":["## Keep distinct behavioral rules, dropping near-duplicates.\n"]},{"cell_type":"code","execution_count":30,"metadata":{"id":"ZnEqSywWRlPa","executionInfo":{"status":"ok","timestamp":1772206253676,"user_tz":-120,"elapsed":5,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"}}},"outputs":[],"source":["def select_distinct_rules(rules, threshold=0.8, model_name=\"all-MiniLM-L6-v2\"):\n","    \"\"\"\n","    Keep distinct behavioral rules, dropping near-duplicates.\n","    Preference = higher (alignment_rate*0.7 + normalized(rule_applied_counts)*0.3)\n","\n","    Args:\n","        rules (list[dict]): each rule must have:\n","            - 'rule_name'\n","            - 'behavior_rule'\n","            - 'rule_applied_counts'\n","            - 'alignment_rate' (0–1)\n","        threshold (float): cosine similarity above which rules are considered duplicates.\n","        model_name (str): embedding model for semantic comparison.\n","\n","    Returns:\n","        kept (list[dict]): distinct rules kept.\n","        redundant (list[dict]): removed rules (with closest match info).\n","        kept_corr (np.ndarray): cosine matrix among kept rules.\n","    \"\"\"\n","    # Filter rules based on rule_applied_counts\n","    initial_rules = [r for r in rules if r.get(\"rule_applied_counts\", 0) >= 5 and r.get(\"alignment_rate\", 0) >= 0.2]\n","    if not initial_rules:\n","        return [], [], np.array([])\n","\n","    # ---- priorities ----\n","    counts = np.array([r[\"rule_applied_counts\"] for r in initial_rules], float)\n","    aligns = np.array([r[\"alignment_rate\"] for r in initial_rules], float)\n","    counts_norm = counts / counts.max() if counts.max() > 0 else counts\n","    priority = 0.7 * aligns + 0.3 * counts_norm\n","\n","    # ---- embeddings ----\n","    model = SentenceTransformer(model_name)\n","    texts = [r[\"behavior_rule\"] for r in initial_rules]\n","    emb = model.encode(texts, normalize_embeddings=True, show_progress_bar=False)\n","    sim = cosine_similarity(emb)\n","\n","    # ---- greedy distinct selection ----\n","    order = np.argsort(-priority)  # high first\n","    kept, redundant = [], []\n","    for idx in order:\n","        if not kept:\n","            kept.append(idx)\n","            continue\n","        # compare to kept ones\n","        max_sim = sim[idx, kept].max()\n","        if max_sim >= threshold:\n","            j = kept[np.argmax(sim[idx, kept])]\n","            redundant.append({\n","                \"rule_name\": initial_rules[idx][\"rule_name\"],\n","                \"redundant_with\": initial_rules[j][\"rule_name\"],\n","                \"similarity\": float(max_sim)\n","            })\n","        else:\n","            kept.append(idx)\n","\n","    kept_rules = [initial_rules[i] for i in kept]\n","\n","    # Handle case where kept is empty after filtering\n","    if not kept:\n","        kept_corr = np.array([])\n","    else:\n","        kept_corr = sim[np.ix_(kept, kept)]\n","\n","    return kept_rules, redundant, kept_corr"]},{"cell_type":"markdown","metadata":{"id":"J2G1Oa5D925d"},"source":["## transform_results_df_to_rules_participants_matrix"]},{"cell_type":"code","execution_count":31,"metadata":{"id":"n-14zgQHR4mm","executionInfo":{"status":"ok","timestamp":1772206253688,"user_tz":-120,"elapsed":7,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"}}},"outputs":[],"source":["def transform_results_df_to_rules_participants_matrix(df):\n","    di = dict()\n","    participants_list = []\n","    res_rules_list = []\n","    for index, row in df.iterrows():\n","        participant = row['p']\n","        res_rules = json.loads(row['res_rules'])\n","        for rule in res_rules['rule_matches']:\n","            participants_list.append(participant)\n","            res_rules_list.append(rule['rule_name'])\n","    di.update({'p': participants_list, 'rule_name': res_rules_list})\n","    new_df =  pd.DataFrame(di)\n","    return new_df"]},{"cell_type":"markdown","metadata":{"id":"prZbSfEU9pzk"},"source":["## plot_bubble_rules"]},{"cell_type":"code","execution_count":32,"metadata":{"id":"5Bn2SjlSRwYP","executionInfo":{"status":"ok","timestamp":1772206253724,"user_tz":-120,"elapsed":16,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"}}},"outputs":[],"source":["def plot_bubble_rules(rule_counts):\n","    rules = []\n","    align_rates = []\n","    sizes = []\n","\n","    for rule_name, stats in rule_counts.items():\n","        applied = stats.get(\"rule_applied_counts\", 0)\n","        correct = stats.get(\"rule_correct_matches\", 0)\n","        if applied == 0:\n","            continue\n","        align_rate = correct / applied * 100\n","        rules.append(rule_name)\n","        align_rates.append(align_rate)\n","        sizes.append(applied * 20)  # scale bubble size\n","\n","    plt.figure(figsize=(12, 6))\n","    plt.scatter(rules, align_rates, s=sizes, alpha=0.6, c=align_rates, cmap=\"coolwarm\", edgecolors=\"k\")\n","    plt.xticks(rotation=75, ha=\"right\")\n","    plt.ylabel(\"Alignment Rate (%)\")\n","    plt.title(\"Rule Alignment Rate (bubble size = number of applications)\")\n","    plt.colorbar(label=\"Alignment Rate (%)\")\n","    plt.tight_layout()\n","    plt.show()"]},{"cell_type":"markdown","metadata":{"id":"mirE_TVr97dr"},"source":["# Main: return V0 rules"]},{"cell_type":"code","execution_count":25,"metadata":{"id":"tlNsKbZzGG26","colab":{"base_uri":"https://localhost:8080/","height":236},"executionInfo":{"status":"error","timestamp":1772206210569,"user_tz":-120,"elapsed":815,"user":{"displayName":"Itay Toledo","userId":"05729151227105408350"}},"outputId":"fc4fc1f3-f385-485c-d9f3-79299d714ef4"},"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/thesis/preparing_rules_v0/extraversion/run_2026-02-03_22-51-00/_rules\n"]},{"output_type":"error","ename":"NameError","evalue":"name 'load_all_rules_from_rules_dir' is not defined","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mNameError\u001b[0m                                 Traceback (most recent call last)","\u001b[0;32m/tmp/ipython-input-405/3952860680.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m      3\u001b[0m \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mrules_folder\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m      4\u001b[0m \u001b[0mfinal_results\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mos\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mpath\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mjoin\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mrun_folder\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m